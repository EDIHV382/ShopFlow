{
  "buildCommand": "cd client && npm install && npm run generate",
  "outputDirectory": "client/.output/public",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/client/.output/public/$1" }]
}
