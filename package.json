{
  "name": "shopflow",
  "version": "1.0.0",
  "description": "ShopFlow - Full-Stack E-Commerce on Vercel + Neon",
  "private": true,
  "scripts": {
    "dev": "vercel dev",
    "build": "cd client && npm install && npm run generate",
    "deploy": "vercel --prod",
    "install:all": "npm install && cd api && npm install && cd ../client && npm install",
    "db:init": "tsx api/_lib/init-db.ts",
    "db:seed": "tsx api/_lib/seed.ts",
    "lint": "eslint . --ext .js,.cjs,.ts,.vue --ignore-path .gitignore",
    "format": "prettier --write .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,vue,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "ecommerce",
    "nuxt",
    "vercel",
    "neon",
    "postgresql",
    "stripe"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vercel/node": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "stripe": "^14.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.2",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "express-rate-limit": "^8.4.1",
    "happy-dom": "^20.9.0",
    "helmet": "^8.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vercel": "^32.4.1",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "vue-eslint-parser": "^10.4.0"
  }
}
